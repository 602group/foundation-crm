# Epic Foundation CRM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is in .gitignore.

# ── OpenAI API (AI Assistant) ──────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Supabase (Database) ────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
# You need TWO Supabase projects: one for production, one for staging.
# Use the correct set of keys per environment.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — KEEP SECRET, server-only

# ── Server Session ─────────────────────────────────────────────
# Generate a long random string: e.g. `openssl rand -hex 32`
SESSION_SECRET=replace-with-a-long-random-string

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (optional) ───────────────────────────────────────────
# ALLOWED_ORIGIN=https://your-staging-domain.vercel.app
