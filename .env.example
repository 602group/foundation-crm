# Epic Foundation CRM — AI Assistant Server
# Copy this file to .env and fill in your values

# Your OpenAI API key — get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Port for the backend server (default: 3001)
PORT=3001

# Optional: restrict which origin can call the API (defaults to localhost only)
# ALLOWED_ORIGIN=http://localhost:5500
